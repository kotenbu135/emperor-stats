# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# docs/site-design/mockups/card-preview から sync-portraits で同期される生成物（git管理はソース側のみ）
/public/portraits/

# data/emperors.json から build-emperor-notes で生成される経緯JSON（git管理はソース側のみ）
/public/emperor-notes/

# data/emperors.json・data/schema から build-data-distribution で生成される配布物（git管理はソース側のみ）
/public/data/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
